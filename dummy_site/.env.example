# Admin login account.
# Set strong values in Vercel Project Settings > Environment Variables.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# GA4 measurement ID. If empty, gtag.js is not injected.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Used for sitemap.xml, robots.txt, canonical URLs, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://dummy.jeezdev.com

# Supabase content store. The publishable key is used for public, RLS-protected reads.
NEXT_PUBLIC_SUPABASE_URL=https://rhhnapntqgqgpqyzrewz.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key for admin CRUD and one-time migration scripts.
# Never prefix this variable with NEXT_PUBLIC_ or expose it to browser code.
SUPABASE_SECRET_KEY=
