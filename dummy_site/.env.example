# Admin login account.
# Set strong values in Vercel Project Settings > Environment Variables.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# GA4 measurement ID. If empty, gtag.js is not injected.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Used for sitemap.xml, robots.txt, canonical URLs, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://dummy.jeezdev.com

# Git-as-DB write path for /admin/new and /admin/[slug]/edit on Vercel.
# Use a fine-scoped GitHub token with Contents read/write permission for this repo.
GITHUB_TOKEN=
GITHUB_OWNER=intellicastle02
GITHUB_REPO=ai-writing-test-dummy
GITHUB_BRANCH=main
GITHUB_CONTENT_DIR=content/posts

# Optional commit author metadata for posts created through the admin UI.
GITHUB_COMMIT_AUTHOR_NAME=AI Writing Bot
GITHUB_COMMIT_AUTHOR_EMAIL=
